<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.Pages.LocationListPage"
             Title="Tour Locations">

    <VerticalStackLayout Padding="20">

        <Label 
            Text="Danh sách địa điểm"
            FontSize="26"
            HorizontalOptions="Center" />

        <CollectionView
            x:Name="locationList"
            SelectionMode="Single"
            SelectionChanged="OnLocationSelected">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Frame Padding="10" Margin="5">

                        <VerticalStackLayout>

                            <Label 
                                Text="{Binding Name}"
                                FontSize="20"
                                FontAttributes="Bold"/>

                            <Label 
                                Text="{Binding Description}"
                                FontSize="14"/>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>