<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TourGuideApp.Pages.RestaurantListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Restaurants">

    <CollectionView x:Name="RestaurantList">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Padding="10" Margin="10">
                    <VerticalStackLayout>
                        <Label
                            FontSize="20"
                            FontAttributes="Bold"
                            Text="{Binding Name}" />

                        <Label
                            FontSize="14"
                            Text="{Binding Description}" />

                        <Button
                            Text="View Detail"
                            Clicked="OnRestaurantClicked"
                            CommandParameter="{Binding Id}" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>